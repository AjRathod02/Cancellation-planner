# Server
PORT=8000
LOG_LEVEL=INFO
SCHEDULE_TIMEZONE=America/Los_Angeles
SCHEDULE_HOUR=4
SCHEDULE_MINUTE=0

# Optional: protect POST/GET /run (leave empty to disable auth)
RUN_API_KEY=

# Post to Teams immediately after each run (true/false)
AUTO_POST=true

# Power Automate HTTP trigger URL (required)
WEBHOOK_URL=

# Microsoft Graph / SharePoint (required)
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_SITE_ID=

# SharePoint file paths (optional overrides)
SP_INVENTORY_PATH=Operations/july_2023_email_scraping/2025_wm_inventory_reservations_details.xlsx
SP_CONFIRMED_PATH=Operations/Confirmed Bookings Guest Reservation Tracking.xlsx
SP_CREDIT_MM_PATH=Operations/july_2023_email_scraping/Credit_and_MMaccount.xlsx
